<ul class="menu">
    {% for item in collections.menuItems | sort(false, false, 'data.order') %}
    <li><a href="{{ item.data.permalink }}" {% if page.url==item.url %} aria-current="page" class="active" {% endif
            %}>{{ item.data.title | slugify }}</a></li>
    {% endfor %}
    <li><a href="https://guestbook.netherpi.net" target="_self">guestbook</a></li>
    <li><a href="/feed.xml">rss</a></li>
</ul>